# ============================================================================
# Texlink Analytics — Environment Variables Template
# Copy to .env and fill in your values. Never commit .env to git.
# ============================================================================

# --- PostgreSQL Connection ---
DATABASE_URL=postgresql://texlink:password@localhost:5432/texlink

PGHOST=localhost
PGPORT=5432
PGDATABASE=texlink
PGUSER=texlink
PGPASSWORD=password

# --- Railway (Production) ---
# These are automatically set by Railway when linked to a PostgreSQL service
# RAILWAY_DATABASE_URL=postgresql://...

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# --- Seed Configuration ---
SEED_EMPRESAS=150
SEED_OFICINAS=400
SEED_MONTHS_OF_HISTORY=18

# --- Analytics ---
LOG_LEVEL=INFO
